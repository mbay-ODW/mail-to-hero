# IMAP server – the inbox the web-form mailer delivers to.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SSL=true
IMAP_FOLDER=INBOX
EMAIL_USER=forms@example.com
EMAIL_PASSWORD=changeme

# Subject prefix that identifies a web-form notification.
SUBJECT_PREFIX=Anfrage von:

# HERO External API.
HERO_API_KEY=ptr_xxxxxxxx
# HERO_GRAPHQL_URL=https://login.hero-software.de/api/external/v7/graphql

# How often to poll for new mails (seconds).
POLL_INTERVAL_SECONDS=60

# Set to true to log what would be created without actually calling HERO.
DRY_RUN=false

# Whether to flag processed mails as Seen on the IMAP server.
MARK_AS_READ=true

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
